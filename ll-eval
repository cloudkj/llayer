#!/bin/sh
set -euo pipefail

usage() {
    cat <<'EOF' >&2
Usage: ll-eval [--model MODEL] [--host HOST] [--port PORT] [--tools] [--dry-run]

Options:
    --model NAME   Model name to request (default: llama3.2:1b)
    --host HOST    Model server host (default: localhost)
    --port PORT    Model server port (default: 11434)
    --tools        Include tool specs from tools.json in the model payload
    --dry-run      Print the model payload only
    -h, --help     Show this message
EOF
}

for cmd in jq curl; do
    if ! command -v $cmd &> /dev/null; then
        echo "Error: $cmd is required but not installed." >&2
        exit 1
    fi
done

HOST="localhost"
PORT="11434"
MODEL_NAME="${LLAYER_MODEL:-llama3.2:1b}"
DRY_RUN=false
TOOLS_JSON="[]"
while [ "$#" -gt 0 ]; do
    case "$1" in
        --tools)
            TOOLS_JSON=$(cat tools.json) || { printf '%s\n' "error: failed to read tools.json" >&2; exit 1; }
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --host)
            if [ "${2:-}" = "" ]; then printf 'Missing value for --host\n' >&2; exit 2; fi
            HOST="$2"
            shift 2
            ;;
        --port)
            if [ "${2:-}" = "" ]; then printf 'Missing value for --port\n' >&2; exit 2; fi
            PORT="$2"
            shift 2
            ;;
        --model)
            if [ "${2:-}" = "" ]; then printf 'Missing value for --model\n' >&2; exit 2; fi
            MODEL_NAME="$2"
            shift 2
            ;;
        -h|--help)
            usage; exit 0
            ;;
        *) printf 'Unknown option: %s\n' "$1" >&2; exit 2 ;;
    esac
done

if [ -z "${MODEL_NAME}" ]; then
    printf '%s\n' "error: --model is required" >&2
    usage
    exit 2
fi

# Read messages from stdin
MESSAGES_JSON=$(cat) || { printf '%s\n' "error: failed to read stdin" >&2; exit 1; }
if [ -z "$(printf '%s' "$MESSAGES_JSON" | tr -d '[:space:]')" ]; then
    exit 0
fi

# Generate model request payload
PAYLOAD=$(printf '%s' "$MESSAGES_JSON" | jq -c --arg model "$MODEL_NAME" --argjson tools "$TOOLS_JSON" '
{
    model: $model,
    messages: .,
    stream: true,
    tools: $tools
}
') || { printf '%s\n' "error: invalid JSON input" >&2; exit 1; }

if [ "$DRY_RUN" = "true" ]; then
    printf '%s\n' "$PAYLOAD"
    exit 0
fi

# Call model and stream parsed events
MODEL_ENDPOINT="http://${HOST}:${PORT}/api/chat"
curl -sS -N -X POST "$MODEL_ENDPOINT" \
-H "Content-Type: application/json" \
-d "$PAYLOAD" | \
jq --unbuffered -R -c '
select(length > 0) | fromjson? |
if .message.tool_calls then
    .message.tool_calls[] | {type: "tool_call", source: "assistant", payload: .function}
elif .message.content then
    if .done == true then
        {type: "message_complete", source: "system", payload: {}}
    else
        {type: "token", source: "assistant", payload: {text: .message.content}}
    end
else
    empty
end
'
