#!/bin/sh
set -euo pipefail

usage() {
    cat <<'EOF' >&2
Usage: ll-eval [--tools] [--dry-run]

Options:
    --tools     Include tool specs from tools.json in the model payload
    --dry-run   Print the model payload only
    -h, --help  Show this message
EOF
}

HOST="localhost"
PORT="11434"
MODEL_ENDPOINT="http://${HOST}:${PORT}/api/chat"
MODEL_NAME="llama3.2:1b"

DRY_RUN=false
TOOLS_JSON="[]"
while [ "$#" -gt 0 ]; do
    case "$1" in
        --tools)
            TOOLS_JSON=$(cat tools.json) || { printf '%s\n' "error: failed to read tools.json" >&2; exit 1; }
            shift
            ;;
        --dry-run) DRY_RUN=true; shift ;;
        -h|--help) usage; exit 0 ;;
        *) printf 'Unknown option: %s\n' "$1" >&2; exit 2 ;;
    esac
done

# Read messages from stdin
MESSAGES_JSON=$(cat) || { printf '%s\n' "error: failed to read stdin" >&2; exit 1; }
if [ -z "$(printf '%s' "$MESSAGES_JSON" | tr -d '[:space:]')" ]; then
    exit 0
fi

# Generate model request payload
PAYLOAD=$(printf '%s' "$MESSAGES_JSON" | jq -c --arg model "$MODEL_NAME" --argjson tools "$TOOLS_JSON" '
{
    model: $model,
    messages: .,
    stream: true,
    tools: $tools
}
') || { printf '%s\n' "error: invalid JSON input" >&2; exit 1; }

if [ "$DRY_RUN" = "true" ]; then
    printf '%s\n' "$PAYLOAD"
    exit 0
fi

# Send to model and stream parsed events
curl -sS -N -X POST "$MODEL_ENDPOINT" \
-H "Content-Type: application/json" \
-d "$PAYLOAD" | \
jq --unbuffered -R -c '
select(length > 0) | fromjson? |
if .message.tool_calls then
    .message.tool_calls[] | {type: "tool_call", source: "assistant", payload: .function}
elif .message.content then
    if .done == true then
        {type: "message_complete", source: "system", payload: {}}
    else
        {type: "token", source: "assistant", payload: {text: .message.content}}
    end
else
    empty
end
'
