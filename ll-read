#!/bin/sh
set -euo pipefail

if ! command -v jq &> /dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
fi

# Set the `source` of a generated message
SOURCE="user"
if [ "${1:-}" = "--system" ]; then
  SOURCE="system"
fi

input=$(cat)

if [ -z "$input" ]; then
  exit 0
fi

printf '%s' "$input" | jq -c -Rs --arg source "$SOURCE" '{type: "message", source: $source, payload: {text: .}}'
