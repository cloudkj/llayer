#!/bin/sh
set -euo pipefail

# Simple extractor: reads newline-delimited JSON events and writes assistant output.
# - token events: append text (no newline)
# - message_complete events: write a newline
# - fallback: message events from assistant -> print payload.text with newline

jq --unbuffered -R -r -j '
    select(length > 0) |
    try fromjson catch null |
    select(. != null) |
    if .type == "token" and .source == "assistant" then
        .payload.text
    elif .type == "message_complete" then
        "\n"
    elif .type == "message" and .source == "assistant" then
        .payload.text, "\n"
    else
        empty
    end
'