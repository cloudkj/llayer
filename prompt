#!/bin/sh
set -eu

# Determine the `source` of a generated message
SOURCE="user"
if [ "${1:-}" = "--system" ]; then
  SOURCE="system"
fi

input=$(cat)

if [ -z "$input" ]; then
  exit 0
fi

# Use jq to safely produce JSON with proper escaping
printf '%s' "$input" | jq -c -Rs --arg source "$SOURCE" '{type: "message", source: $source, payload: {text: .}}'
