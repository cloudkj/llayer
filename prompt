#!/bin/sh
set -eu

# Require jq for JSON encoding
if ! command -v jq >/dev/null 2>&1; then
  printf '%s\n' "error: jq is required but not installed" >&2
  exit 1
fi

input=$(cat)

if [ -z "$input" ]; then
  exit 0
fi

# Use jq to safely produce JSON with proper escaping
printf '%s' "$input" | jq -c -Rs '{type: "message", source: "user", payload: {text: .}}'
