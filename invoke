#!/usr/bin/env python3
"""
Stream messages to Ollama API via HTTP and emit token events as newline-delimited JSON.
Reads a JSON array of messages from stdin, sends to Ollama, and streams token responses.
"""

import json
import sys
import argparse
import requests
from typing import Generator, Any

MODEL_NAME = "llama3.2:1b"

TOOLS = [
    {
        "type": "function",
        "function": {
            "name": "list_directory",
            "description": "Lists the files and folders inside a specified local directory.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "The absolute or relative path to the directory to list. Use '.' for the current directory."
                    }
                },
                "required": ["path"]
            }
        }
    }
]


def parse_args() -> argparse.Namespace:
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(
        description="Stream messages to Ollama API"
    )
    parser.add_argument(
        "--host",
        default="localhost",
        help="Ollama host (default: localhost)"
    )
    parser.add_argument(
        "--port",
        type=int,
        default=11434,
        help="Ollama port (default: 11434)"
    )
    parser.add_argument(
        "--url",
        help="Full Ollama API URL (overrides host/port)"
    )
    return parser.parse_args()


def stream_ollama(
    messages: list[dict[str, Any]],
    ollama_url: str
) -> Generator[dict[str, Any], None, None]:
    """
    Stream response from Ollama API and parse events.
    
    Yields event dicts with keys: type, source, payload
    """
    payload = {
        "model": MODEL_NAME,
        "messages": messages,
        "stream": True,
        "tools": TOOLS
    }
    
    try:
        response = requests.post(
            ollama_url,
            json=payload,
            stream=True,
            timeout=None
        )
        response.raise_for_status()
        
        for line in response.iter_lines():
            if not line:
                continue
            
            try:
                data = json.loads(line)
            except json.JSONDecodeError:
                continue
            
            # Parse response and emit events
            if "message" in data:
                message = data["message"]
                
                if "tool_calls" in message:
                    for tool_call in message.get("tool_calls", []):
                        if "function" in tool_call:
                            yield {
                                "type": "tool_calls",
                                "source": "assistant",
                                "payload": [tool_call["function"]]
                            }
                elif "tool_result" in message:
                    tool_result = message["tool_result"]
                    yield {
                        "type": "tool_result",
                        "source": "assistant",
                        "payload": {
                            "name": tool_result.get("name"),
                            "result": tool_result.get("result")
                        }
                    }
                elif "content" in message:
                    yield {
                        "type": "token",
                        "source": "assistant",
                        "payload": {"text": message["content"]}
                    }
            
            if data.get("done"):
                yield {
                    "type": "message_complete",
                    "source": "system",
                    "payload": {}
                }
    
    except requests.RequestException as e:
        print(f"Error: Failed to connect to Ollama at {ollama_url}", file=sys.stderr)
        print(f"Details: {e}", file=sys.stderr)
        sys.exit(1)


def main() -> None:
    """Main entry point."""
    args = parse_args()
    
    # Construct URL
    if args.url:
        ollama_url = args.url
    else:
        ollama_url = f"http://{args.host}:{args.port}/api/chat"
    
    # Read messages from stdin
    try:
        messages_json = sys.stdin.read()
    except (KeyboardInterrupt, BrokenPipeError):
        sys.exit(0)
    
    if not messages_json.strip():
        sys.exit(0)
    
    try:
        messages = json.loads(messages_json)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON input: {e}", file=sys.stderr)
        sys.exit(1)
    
    # Stream and output events
    try:
        for event in stream_ollama(messages, ollama_url):
            print(json.dumps(event))
    except BrokenPipeError:
        sys.exit(0)


if __name__ == "__main__":
    main()
