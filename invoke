#!/usr/bin/env python3
import argparse
import os
import sys
import json
import urllib.request

MODEL_NAME = "llama3.2:1b"

def get_ollama_url(host, port):
    return f"http://{host}:{port}/api/chat"

def stream_llm(messages_array, ollama_url):
    api_payload = {
        "model": MODEL_NAME,
        "messages": messages_array,
        "stream": True
    }
    
    req = urllib.request.Request(
        ollama_url,
        data=json.dumps(api_payload).encode('utf-8'),
        headers={'Content-Type': 'application/json'}
    )
    
    try:
        with urllib.request.urlopen(req) as response:
            for line in response:
                if not line.strip():
                    continue
                
                chunk = json.loads(line.decode('utf-8'))
                token = chunk.get("message", {}).get("content", "")
                
                if token:
                    token_event = {
                        "type": "token",
                        "source": "assistant",
                        "payload": {"text": token}
                    }
                    print(json.dumps(token_event))
                    sys.stdout.flush()
                    
                if chunk.get("done", False):
                    completion_event = {
                        "type": "message_complete",
                        "source": "system",
                        "payload": {}
                    }
                    print(json.dumps(completion_event))
                    sys.stdout.flush()

    except Exception as e:
        sys.stderr.write(f"Streaming Error: {e}\n")


def parse_args():
    parser = argparse.ArgumentParser(description="Invoke Ollama via stdin/stdout JSON pipeline.")
    parser.add_argument("--host", default=os.environ.get("OLLAMA_HOST", "localhost"), help="Ollama host (env: OLLAMA_HOST)")
    parser.add_argument("--port", default=os.environ.get("OLLAMA_PORT", "11434"), help="Ollama port (env: OLLAMA_PORT)")
    parser.add_argument("--url", default=None, help="Full Ollama endpoint URL; overrides host/port and env vars")
    return parser.parse_args()


def main():
    args = parse_args()
    ollama_url = args.url or get_ollama_url(args.host, args.port)

    input_data = sys.stdin.read().strip()
    if not input_data:
        return
        
    try:
        # Expects the complete array outputted by llm-context
        messages = json.loads(input_data)
        if isinstance(messages, list):
            stream_llm(messages, ollama_url)
        else:
            sys.stderr.write("Pipeline Error: llm-invoke expected a JSON array of messages.\n")
    except Exception as e:
        sys.stderr.write(f"Pipeline Input Error: {e}\n")

if __name__ == "__main__":
    main()
