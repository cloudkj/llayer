#!/bin/bash
set -euo pipefail

HISTORY_FILE=".llayer_history"
LATEST_FILE=".llayer_latest"

if [ ! -f "$HISTORY_FILE" ]; then
    touch "$HISTORY_FILE"
fi

while true; do
    read -r -p "> " line
    if [ -z "$line" ]; then
        continue
    fi
    case "$line" in
        exit|quit)
            echo "Goodbye."
            break
            ;;
    esac

    echo "$line" | ./observe >> "$HISTORY_FILE"

    cat "$HISTORY_FILE" | ./orient | ./decide | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./act

    until cat "$LATEST_FILE" | ./invoke >> "$HISTORY_FILE"; do
        cat "$HISTORY_FILE" | ./orient | ./decide | ./invoke | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./act
    done
done
