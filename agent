#!/bin/bash
set -euo pipefail

HISTORY_FILE=".llayer_history"
LATEST_FILE=".llayer_latest"

if [ ! -f "$HISTORY_FILE" ]; then
    touch "$HISTORY_FILE"
fi

while true; do
    read -r -p "> " line
    if [ -z "$line" ]; then
        continue
    fi
    USE_TOOLS=false
    case "$line" in
        exit|quit)
            echo "Goodbye."
            break
            ;;
        /tools*)
            USE_TOOLS=true
            line="${line#/tools }"
            ;;
    esac

    echo "$line" | ./prompt >> "$HISTORY_FILE"

    DECIDE_ARGS=""
    [ "$USE_TOOLS" = true ] && DECIDE_ARGS="--tools"
    cat "$HISTORY_FILE" | ./compact | ./invoke $DECIDE_ARGS | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./extract

    until cat "$LATEST_FILE" | ./dispatch >> "$HISTORY_FILE"; do
        cat "$HISTORY_FILE" | ./compact | ./invoke | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./extract
    done
done
