#!/bin/bash
set -euo pipefail

HISTORY_FILE=".llayer_history"
LATEST_FILE=".llayer_latest"

if [ ! -f "$HISTORY_FILE" ]; then
    touch "$HISTORY_FILE"
fi

while true; do
    read -r -p "> " line
    if [ -z "$line" ]; then
        continue
    fi
    USE_TOOLS=false
    case "$line" in
        exit|quit)
            echo "Goodbye."
            break
            ;;
        /tools*)
            USE_TOOLS=true
            line="${line#/tools }"
            ;;
    esac

    echo "$line" | ./observe >> "$HISTORY_FILE"

    DECIDE_ARGS=""
    [ "$USE_TOOLS" = true ] && DECIDE_ARGS="--tools"
    cat "$HISTORY_FILE" | ./orient | ./decide $DECIDE_ARGS | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./act

    until cat "$LATEST_FILE" | ./invoke >> "$HISTORY_FILE"; do
        cat "$HISTORY_FILE" | ./orient | ./decide | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./act
    done
done
