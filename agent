#!/bin/bash
set -euo pipefail

HISTORY_FILE=".llayer_history"

if [ ! -f "$HISTORY_FILE" ]; then
    touch "$HISTORY_FILE"
fi

while true; do
    read -r -p "> " line
    if [ -z "$line" ]; then
        continue
    fi
    case "$line" in
        exit|quit)
            echo "Goodbye."
            break
            ;;
    esac

    echo "$line" | ./prompt >> "$HISTORY_FILE"

    cat "$HISTORY_FILE" | ./compact | ./invoke | tee -a "$HISTORY_FILE" | ./extract

done
