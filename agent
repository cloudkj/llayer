#!/bin/bash
set -euo pipefail

HISTORY_FILE=".llayer_history"
LATEST_FILE=".llayer_latest"

if [ ! -f "$HISTORY_FILE" ]; then
    touch "$HISTORY_FILE"
fi

while true; do
    read -r -p "> " line
    if [ -z "$line" ]; then
        continue
    fi
    USE_TOOLS=false
    case "$line" in
        exit|quit)
            printf "Goodbye.\n"
            break
            ;;
        /tools*)
            USE_TOOLS=true
            line="${line#/tools }"
            ;;
    esac

    printf '%s\n' "$line" | ./ll-read >> "$HISTORY_FILE"

    MODEL_ARG="--model llama3.2:1b"
    ENABLE_TOOLS=""
    [ "$USE_TOOLS" = true ] && ENABLE_TOOLS="--tools"
    cat "$HISTORY_FILE" | ./ll-context | ./ll-eval $MODEL_ARG $ENABLE_TOOLS | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./ll-print

    until cat "$LATEST_FILE" | ./ll-dispatch >> "$HISTORY_FILE"; do
        cat "$HISTORY_FILE" | ./ll-context | ./ll-eval | tee -a "$HISTORY_FILE" | tee "$LATEST_FILE" | ./ll-print
    done
done
