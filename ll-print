#!/bin/sh
set -euo pipefail

usage() {
    cat <<'EOF' >&2
Usage: ll-print [--debug]

Options:
  --debug     Emit message events from all sources
  -h, --help  Show this message
EOF
}

DEBUG=false
while [ "$#" -gt 0 ]; do
    case "$1" in
        --debug) DEBUG=true; shift ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Unknown option: $1" >&2; usage; exit 2 ;;
    esac
done

jq --unbuffered -R -r -j --arg debug "$DEBUG" '
    select(length > 0) |
    try fromjson catch null |
    select(. != null) |
    if .type == "token" and ($debug == "true" or .source == "assistant") then
        .payload.text
    elif .type == "message_complete" then
        "\n"
    elif .type == "message" and ($debug == "true" or .source == "assistant") then
        if $debug == "true" then
            "[", (.source // ""), "] ", .payload.text,  "\n"
        else
            .payload.text, "\n"
        end
    else
        empty
    end
'
