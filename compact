#!/bin/sh
set -euo pipefail

# Require jq for JSON processing
if ! command -v jq >/dev/null 2>&1; then
    printf '%s\n' "error: jq is required but not installed" >&2
    exit 1
fi

#
# compact - convert newline-delimited JSON events into a compact message array
#
# This script performs three clear passes implemented with jq:
# 1) Parse raw input lines into a JSON array of events
# 2) Reconstruct assistant messages from token events
# 3) Select system messages and the last 10 non-system messages and
#    normalize them to {role, content} pairs
#
# The output is a JSON array suitable for feeding into other tools.
#

jq -R -s '
    # Split input into lines, drop empty lines, try to parse JSON per-line
    split("\n")
    | map(select(length > 0))
    | map(try fromjson catch null)
    | map(select(. != null))
' | \

jq -c '
    # Reconstruct messages from token stream. Maintain a token buffer while
    # streaming assistant tokens and emit a message when a message_complete
    # event is seen (or at the end).
    reduce .[] as $event (
        {reconstructed: [], token_buffer: ""};
        if ($event.type == "message" or $event.type == "tool_call" or $event.type == "tool_result") then
            .reconstructed += [$event]
        elif ($event.type == "token" and $event.source == "assistant") then
            .token_buffer += ($event.payload.text // "")
        elif $event.type == "message_complete" then
            if .token_buffer != "" then
                .reconstructed += [{
                    type: "message",
                    source: "assistant",
                    payload: {text: .token_buffer}
                }] |
                .token_buffer = ""
            else
                .
            end
        else
            .
        end
    )
    # If there are leftover tokens, flush them as a final assistant message
    | if .token_buffer != "" then
            .reconstructed += [{
                type: "message",
                source: "assistant",
                payload: {text: .token_buffer}
            }]
        else
            .
        end
    | .reconstructed
' | \

jq -c '
    # Select system messages (all) plus the last 10 non-system messages,
    # then normalize each event to {role, content}. Handle tool events
    # explicitly and include a tool_name field when present.
    (
        map(select(.source == "system" and .type == "message")) as $system_events |
        (map(select(.source != "system")) | .[-10:]) as $recent_events |
        ($system_events + $recent_events)
    )
    | map(
            if .source == "tool" then
                {
                    role: "tool",
                    content: (.payload.text // (.payload.result | tostring) // (.payload | tostring)),
                    tool_name: (.payload.tool_name // .payload.name // "unknown_tool")
                }
            else
                {
                    role: (if (.source | IN("assistant", "user", "system")) then .source else "user" end),
                    content: (.payload.text // tostring)
                }
            end
        )
'
