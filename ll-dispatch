#!/bin/bash
set -euo pipefail

for cmd in jq curl; do
    if ! command -v $cmd &> /dev/null; then
        echo "Error: $cmd is required but not installed." >&2
        exit 1
    fi
done

list_directory() {
  local line="$1"
  local target_path

  target_path=$(printf '%s' "$line" | jq -r '.path')
  if [ -z "$target_path" ]; then
    printf 'Error: "path" argument is required for list_directory\n' >&2
    return 1
  fi

  if list_output=$(ls -1 -- "$target_path" 2>&1); then
    printf 'Contents of %s:\n%s' "$target_path" "$list_output"
  else
    printf 'Error listing directory %s: %s' "$target_path" "$list_output"
  fi
}

print_file() {
  local line="$1"
  local target_path

  target_path=$(printf '%s' "$line" | jq -r '.path')
  if [ -z "$target_path" ]; then
    printf 'Error: "path" argument is required for print_file\n' >&2
    return 1
  fi

  if file_output=$(cat -- "$target_path" 2>&1); then
    printf 'Contents of %s:\n%s' "$target_path" "$file_output"
  else
    printf 'Error reading file %s: %s' "$target_path" "$file_output"
  fi
}

fetch_url() {
  local url=$(printf '%s' "$1" | jq -r '.url')
  # Fetch, strip HTML tags, collapse spaces, and truncate to avoid blowing out context
  curl -sL "$url" | sed -e 's/<[^>]*>//g' -e 's/^[ \t]*//;s/[ \t]*$//' | tr -s ' \n' ' ' | head -c 4096
}

dispatch() {
  local tool_name="$1"
  local tool_arguments="$2"

  case "$tool_name" in
    list_directory)
      list_directory "$tool_arguments"
      ;;
    print_file)
      print_file "$tool_arguments"
      ;;
    fetch_url)
      fetch_url "$tool_arguments"
      ;;
    *)
      printf 'Unknown tool: %s\n' "$tool_name" >&2
      return 1
      ;;
  esac
}

tool_calls=0
while IFS=$'\t' read -r tool_name tool_arguments; do
    if ! result=$(dispatch "$tool_name" "$tool_arguments"); then
        continue
    fi

    tool_calls=$((tool_calls + 1))
    printf '%s\n' "$(
        jq -nc --arg tool_name "$tool_name" --arg text "$result" \
          '{type: "tool_result", source: "tool", payload: {tool_name: $tool_name, text: $text}}'
    )"
done < <(jq -r -s 'map(select(.type == "tool_call"))[] | [.payload.name, (.payload.arguments | @json)] | @tsv')

if [ "$tool_calls" -gt 0 ]; then
  exit 1
else
  exit 0
fi
